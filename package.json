{
  "name": "gemini-live-agent",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24.14.0 <25",
    "npm": ">=11.9.0 <12"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:desktop": "npm run dev --workspace @agent/desktop",
    "dev:live-text-session": "tsx scripts/dev-live-text-session.ts",
    "dev:text-session": "tsx scripts/dev-text-session.ts",
    "smoke:gemini": "node scripts/smoke-gemini-cli.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
